                            "type":"object",
                            "required":["marcador", "minut", "jugador"],
                            "properties": {
                                "marcador": {
                                    "type": "string",
                                    "pattern": "^[0-9]+-[0-9]+$"
                                },
                                "minut": {
                                    "type": "string",
                                    "pattern": "^[0-9]{1,2}:[0-9]{2}$"
                                },
                                "jugador": {
                                    "type": "string"
                                },
                                "penalti": {
                                    "type": "boolean",
                                    "const": true
                                }
                            }
                        }
                    },
                    "targetes": {
                        "type": "array",
                        "items": {
                            "type":"object",
                            "required":["tipus", "minut", "jugador"],
                            "properties": {
                                "tipus": {
                                    "type": "string",
                                    "enum": ["groga", "roja"]
                                },
                                "minut": {
                                    "type": "string",
                                    "pattern": "^[0-9]{1,2}:[0-9]{2}$"
                                },
                                "jugador": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }

